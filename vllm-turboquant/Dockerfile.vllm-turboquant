ARG BASE_IMAGE="registry.100credit.cn/xdynamic/x86_64/nvidia/vllm-openai:v0.20.0"
FROM ${BASE_IMAGE}

USER root

ARG TURBOQUANT_GIT_URL="https://github.com/0xSero/turboquant.git"
ARG TURBOQUANT_GIT_REF="main"

COPY turboquant_vllm_patch/sitecustomize.py /tmp/tq_vllm_patch.py

# Keep base-image startup behavior unchanged:
# - do not override ENTRYPOINT/CMD
# - install TurboQuant + auto-load patch via .pth in site-packages
RUN set -eux; \
  if ! command -v git >/dev/null 2>&1; then \
    if command -v apt-get >/dev/null 2>&1; then \
      apt-get update && apt-get install -y --no-install-recommends git ca-certificates && rm -rf /var/lib/apt/lists/*; \
    elif command -v dnf >/dev/null 2>&1; then \
      dnf install -y git ca-certificates && dnf clean all; \
    elif command -v yum >/dev/null 2>&1; then \
      yum install -y git ca-certificates && yum clean all; \
    elif command -v microdnf >/dev/null 2>&1; then \
      microdnf install -y git ca-certificates && microdnf clean all; \
    elif command -v apk >/dev/null 2>&1; then \
      apk add --no-cache git ca-certificates; \
    else \
      echo "No supported package manager found to install git" >&2; \
      exit 1; \
    fi; \
  fi; \
  python3 -m pip install --no-cache-dir "git+${TURBOQUANT_GIT_URL}@${TURBOQUANT_GIT_REF}" \
  && python3 - <<'PY'
import os
import shutil
import sysconfig

purelib = sysconfig.get_paths()["purelib"]
os.makedirs(purelib, exist_ok=True)

patch_module = os.path.join(purelib, "tq_vllm_patch.py")
shutil.copyfile("/tmp/tq_vllm_patch.py", patch_module)

pth_path = os.path.join(purelib, "zzz_turboquant_vllm_autoload.pth")
with open(pth_path, "w", encoding="utf-8") as f:
    f.write("import tq_vllm_patch\n")

print(f"[install] purelib={purelib}")
print(f"[install] patch_module={patch_module}")
print(f"[install] pth={pth_path}")
PY
